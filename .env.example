# ============================================================
# NexDocIQ — Root Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ============================================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nexdociq

# Google Gemini API Key
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Deployed frontend URL (for CORS — fill in after deploying frontend)
FRONTEND_URL=https://your-nexdociq-frontend.vercel.app

# Local dev port (Vercel ignores this)
PORT=5000
