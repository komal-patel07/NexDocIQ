# ============================================================
# NexDocIQ — Root .gitignore
# ============================================================

# ---- Node ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ---- Environment / Secrets (NEVER commit these) ----
.env
.env.local
.env.*.local
.env.production
.env.development
backend/.env

# ---- Build outputs ----
dist/
dist-ssr/
build/
out/
frontend/dist/

# ---- Vite / frontend ----
*.local

# ---- Uploads & temp files (backend) ----
backend/uploads/
backend/tmp/
backend/data/uploads/
backend/data/*.json

# ---- OS files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editor ----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


