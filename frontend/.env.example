# ============================================================
# NexDocIQ Frontend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# All Vite env vars MUST be prefixed with VITE_
# ============================================================

# URL of your deployed backend API
# - For local development: leave empty (Vite proxy handles it automatically)
# - For production (Vercel): set to your deployed backend URL
VITE_API_URL=https://your-nexdociq-backend.vercel.app
